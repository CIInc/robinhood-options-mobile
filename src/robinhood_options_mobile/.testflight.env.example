# Copy this file to .testflight.env and fill in the values from:
# App Store Connect > Users and Access > Integrations > App Store Connect API.
# The API key needs permission to upload builds (App Manager is sufficient).
APP_STORE_CONNECT_API_KEY_ID="YOUR_KEY_ID"
APP_STORE_CONNECT_API_ISSUER_ID="YOUR_ISSUER_ID"

# Store the downloaded key at one of Apple's supported locations, preferably:
# ~/.appstoreconnect/private_keys/AuthKey_YOUR_KEY_ID.p8
